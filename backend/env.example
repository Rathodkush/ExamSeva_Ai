## Backend environment variables (example)
## Copy this file to `backend/.env` and adjust values.

# Server
PORT=4000
JWT_SECRET=change-this-in-production

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/examsevaDB

# Initial admin (optional). If set, an admin user is created on startup (once).
ADMIN_EMAIL=admin@examseva.com
ADMIN_PASSWORD=StrongAdminPass123
ADMIN_NAME=ExamSeva Super Admin

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-google-client-id

# Python service base URL (optional)
# PYTHON_URL_BASE=http://127.0.0.1:5000

